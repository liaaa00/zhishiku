        <h2>{{ sourceTitle(source) }}</h2>
        <p>{{ sourceType(source) }} · {{ sourceLocation(source) }}</p>
      </div>
      <div class="drawer-evidence">
        <el-tag size="small" effect="light">{{ sourceScoreLabel(source) }}</el-tag>
        <span>{{ sourceMatchReason(source) }}</span>
      </div>
      <el-alert v-if="previewError" class="drawer-alert" type="warning" :title="previewError" show-icon :closable="false" />
      <section class="drawer-source-content">
        <h3>命中片段上下文</h3>
        <div ref="previewBoxRef" class="preview-box">
          <template v-if="displaySegments.length">
            <span v-for="(segment, index) in displaySegments" :key="index" :class="{ 'hit-mark': segment.hit }">{{ segment.text }}</span>
          </template>
          <template v-else>该引用未返回片段内容。</template>
        </div>
      </section>
      <div class="drawer-actions">
        <el-button type="primary" @click="openSourceFile(source)">打开知识库文件</el-button>
        <el-button plain @click="loadPreview(source)">重新加载预览</el-button>
      </div>
    </template>
  </el-drawer>
</template>

<script setup lang="ts">
import { computed, nextTick, ref, watch } from 'vue'
import { ElAlert } from 'element-plus/es/components/alert/index'
import { ElButton } from 'element-plus/es/components/button/index'
import { ElDrawer } from 'element-plus/es/components/drawer/index'
import { ElMessage } from 'element-plus/es/components/message/index'
import { ElTag } from 'element-plus/es/components/tag/index'
import 'element-plus/es/components/alert/style/css'
import 'element-plus/es/components/button/style/css'
import 'element-plus/es/components/drawer/style/css'
import 'element-plus/es/components/message/style/css'
import 'element-plus/es/components/tag/style/css'
import http from '../../../api'
import {
  absoluteApiUrl,
  sourceHighlightSegments,
  sourceLocation,
  sourceMatchReason,
  sourceOpenUrl,
  sourcePreviewUrl,
  sourceScoreLabel,
  sourceSnippet,
  sourceTitle,
  sourceType,
  type SourceItem,
} from '../../../utils/source-utils'

const visible = defineModel<boolean>('visible', { default: false })
const source = defineModel<SourceItem | null>('source', { default: null })
const previewText = defineModel<string>('previewText', { default: '' })
const previewError = defineModel<string>('previewError', { default: '' })
const previewBoxRef = ref<HTMLElement | null>(null)

const displaySegments = computed(() => (source.value ? sourceHighlightSegments(source.value, previewText.value || sourceSnippet(source.value)) : []))

function getErrorDetail(errorValue: any, fallback: string) {
  return errorValue?.response?.data?.detail || errorValue?.message || fallback
}

async function scrollToHit() {
  await nextTick()
  const box = previewBoxRef.value
  if (!box) return
  const hit = box.querySelector('.hit-mark') as HTMLElement | null
  if (hit) {
    box.scrollTop = Math.max(hit.offsetTop - 72, 0)
  }
}

async function loadPreview(currentSource: SourceItem) {
  const url = absoluteApiUrl(sourcePreviewUrl(currentSource))
  if (!url) {
    previewText.value = sourceSnippet(currentSource)
    await scrollToHit()
    return
  }
  try {
    const response = await http.get(url.replace(/^\/api/, ''))
    const data = response.data
    const content = data?.content || data?.snippet || data?.excerpt || ''
    if (Array.isArray(data?.chunks)) {
      previewText.value = data.chunks.map((chunk: any) => chunk.content || chunk.text).filter(Boolean).join('\n\n') || content
    } else {
      previewText.value = content || sourceSnippet(currentSource)
    }
  } catch (requestError: any) {
    previewText.value = sourceSnippet(currentSource)
    previewError.value = getErrorDetail(requestError, '预览加载失败，可尝试直接打开文件')
  } finally {
    await scrollToHit()
  }
}

function openSourceFile(currentSource: SourceItem) {
  const url = absoluteApiUrl(sourceOpenUrl(currentSource))
  if (!url) {
    ElMessage.warning('该引用未提供可打开的文件地址')
    return
  }
  window.open(url, '_blank', 'noopener,noreferrer')
}

watch(
  () => [visible.value, source.value] as const,
  ([isVisible, currentSource]) => {
    if (!isVisible || !currentSource) return
    previewText.value = ''
    previewError.value = ''
    loadPreview(currentSource)
  },
)
</script>

