-  ],
+  routes,
+})
+
+function clearAuth() {
+  localStorage.removeItem('token')
+  localStorage.removeItem('user')
+}
+
+function cachedUserIsAdmin() {
+  const userRaw = localStorage.getItem('user')
+  if (!userRaw) return false
+  try {
+    return !!JSON.parse(userRaw)?.is_admin
+  } catch {
+    localStorage.removeItem('user')
+    return false
+  }
+}
+
+async function verifyUserWithServer(token: string) {
+  const response = await fetch('/api/me', { headers: { Authorization: `Bearer ${token}` } })
+  if (!response.ok) throw new Error('unauthorized')
+  const user = await response.json()
+  localStorage.setItem('user', JSON.stringify(user))
+  return user
+}
+
+router.beforeEach(async (to) => {
+  const token = localStorage.getItem('token')
+  if (to.meta.requiresAuth && !token) return '/login'
+
+  if (to.path === '/login' && token) {
+    try {
+      await verifyUserWithServer(token)
+      return '/chat'
+    } catch {
+      clearAuth()
+      return true
+    }
+  }
+
+  if (!to.meta.requiresAdmin) return true
+  if (!token) return '/login'
+  if (!cachedUserIsAdmin()) return '/chat'
+
+  try {
+    const user = await verifyUserWithServer(token)
+    if (!user?.is_admin) return '/chat'
+  } catch {
+    clearAuth()
+    return '/login'
+  }
+  return true
 })
+
+export default router
