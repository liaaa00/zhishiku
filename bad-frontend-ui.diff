+const feedbackSummary = computed(() => {
+  const summary = { total: feedbacks.value.length, new: 0, reviewed: 0, resolved: 0, ignored: 0 }
+  for (const item of feedbacks.value) {
+    if (item.status in summary) summary[item.status as keyof typeof summary] += 1
+  }
+  return summary
+})
+
+const filteredFeedbacks = computed(() => {
+  const keyword = feedbackKeyword.value.trim().toLowerCase()
+  const category = feedbackCategoryFilter.value
+  return feedbacks.value.filter((item) => {
+    if (category !== 'all' && item.category !== category) return false
+    if (!keyword) return true
+    const haystack = [
+      item.username,
+      item.user_id,
+      item.rating,
+      categoryLabel(item.category),
+      item.category,
+      item.content,
+      item.question,
+      item.answer,
+      item.review_note,
+    ]
+      .filter(Boolean)
+      .join('\n')
+      .toLowerCase()
+    return haystack.includes(keyword)
+  })
+})
