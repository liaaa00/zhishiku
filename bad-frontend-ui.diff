+  { path: '/', redirect: '/chat' },
+  { path: '/login', component: () => import('./views/login/index.vue'), meta: { requiresAuth: false } },
+  { path: '/chat', component: () => import('./views/chat/index.vue'), meta: { requiresAuth: true } },
