export interface SourceItem {
  document_id?: string
  document_title?: string
  filename?: string
  chunk_id?: string
  page_number?: number | string | null
  chunk_index?: number | string | null
  source_type?: string
  content?: string
  snippet?: string
  excerpt?: string
  view_url?: string
  content_url?: string
  url?: string
  score?: number | string | null
  relevance_score?: number | string | null
  similarity?: number | string | null
  confidence?: number | string | null
  match_reason?: string
  reason?: string
  hit_reason?: string
  location?: string
  file_path?: string
  section_title?: string
  page_label?: string
  match_text?: string
  highlighted_text?: string
  highlight?: string
  summary_source?: boolean
  chunks_used?: number | string | null
  total_chunks?: number | string | null
  [key: string]: unknown
}

export interface TextSegment {
  text: string
  hit: boolean
}

export function pickFirstArray(...values: unknown[]): SourceItem[] {
  for (const value of values) {
    if (Array.isArray(value)) return value.filter(Boolean) as SourceItem[]
  }
  return []
}

export function normalizeSourceList(...values: unknown[]): SourceItem[] {
  return pickFirstArray(...values).map((source) => ({
    ...source,
    document_title: source.document_title || source.filename || source.document_id || '未知来源',
    content: source.content || source.snippet || source.excerpt || '',
    view_url: source.view_url || source.url || '',
    content_url: source.content_url || '',
  }))
}

export function sourceTitle(source: SourceItem): string {
  return String(source.document_title || source.filename || source.document_id || '未知来源')
}

export function sourceSnippet(source: SourceItem): string {
  return String(source.content || source.snippet || source.excerpt || source.highlighted_text || '')
}

export function sourcePage(source: SourceItem): string {
  if (source.page_label) return String(source.page_label)
  if (source.page_number === 0 || source.page_number) return `第 ${source.page_number} 页`
  if (source.chunk_index === 0 || source.chunk_index) return `片段 ${source.chunk_index}`
  return '页码未知'
}

export function sourceLocation(source: SourceItem): string {
  const parts = [sourcePage(source)]
  if (source.section_title) parts.push(String(source.section_title))
  if (source.location) parts.push(String(source.location))
  if (source.file_path && !parts.includes(String(source.file_path))) parts.push(String(source.file_path))
  return parts.filter(Boolean).join(' · ')
}

export function sourceType(source: SourceItem): string {
  const type = String(source.source_type || '')
  if (type.startsWith('chat_')) return '个人附件'
  if (type) return type
  return '知识库文件'
}

export function sourceScoreValue(source: SourceItem): number | null {
  const raw = source.relevance_score ?? source.score ?? source.similarity ?? source.confidence
  if (raw === null || raw === undefined || raw === '') return null
  const score = Number(raw)
  if (Number.isNaN(score)) return null
  return score > 1 ? Math.min(score, 100) : Math.max(score, 0) * 100
}

export function sourceScoreLabel(source: SourceItem): string {
  const score = sourceScoreValue(source)
  return score === null ? '相关度未知' : `相关度 ${Math.round(score)}%`
}

export function sourceMatchReason(source: SourceItem): string {
  const reason = source.match_reason || source.hit_reason || source.reason
  if (reason) return String(reason)
  if (source.match_text || source.highlight || source.highlighted_text) return '命中片段与问题关键词相近'
  return '检索结果与问题语义相关'
}

export function sourceHighlightNeedle(source: SourceItem): string {
  return String(source.match_text || source.highlight || '')
}

function escapeRegExp(value: string) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
}

export function sourceHighlightSegments(source: SourceItem, textOverride?: string): TextSegment[] {
  const text = textOverride || sourceSnippet(source)
  const needle = sourceHighlightNeedle(source).trim()
  if (!text) return []
  if (!needle || !text.toLowerCase().includes(needle.toLowerCase())) return [{ text, hit: false }]

  const segments: TextSegment[] = []
  const regex = new RegExp(escapeRegExp(needle), 'ig')
  let lastIndex = 0
  for (const match of text.matchAll(regex)) {
    const index = match.index ?? 0
    if (index > lastIndex) segments.push({ text: text.slice(lastIndex, index), hit: false })
    segments.push({ text: text.slice(index, index + match[0].length), hit: true })
    lastIndex = index + match[0].length
  }
  if (lastIndex < text.length) segments.push({ text: text.slice(lastIndex), hit: false })
  return segments.length ? segments : [{ text, hit: false }]
}

export function sourceKey(source: SourceItem, index: number): string {
  return String(source.chunk_id || source.document_id || source.view_url || source.content_url || index)
}

export function sourceOpenUrl(source: SourceItem): string {
  return String(source.view_url || source.url || source.content_url || '')
}

export function sourcePreviewUrl(source: SourceItem): string {
  return String(source.content_url || source.view_url || source.url || '')
}

export function absoluteApiUrl(url: string): string {
  if (!url) return ''
  if (/^https?:\/\//i.test(url)) return url
  return url.startsWith('/') ? url : `/${url}`
}

