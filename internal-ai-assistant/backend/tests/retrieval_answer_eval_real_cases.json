{
  "description": "PostgreSQL + Qdrant production answer and citation evaluation cases.",
  "defaults": {
    "username": "admin",
    "top_k": 8,
    "knowledge_scope": "all"
  },
  "cases": [
    {
      "id": "answer_real_employee_esign",
      "category": "流程回答与跨文档引用",
      "question": "员工怎么签署电子劳动合同？",
      "expected": {
        "top_n": 5,
        "top_n_must_match_titles": [
          "电子劳动合同",
          "微助手"
        ]
      },
      "answer_expected": {
        "must_include_terms": [
          "电子劳动合同",
          "签署",
          "实名认证"
        ]
      },
      "citation_expected": {
        "min_count": 2,
        "max_count": 8,
        "must_match_titles": [
          "电子劳动合同",
          "微助手"
        ],
        "must_not_match_titles": [
          "入职人员信息表"
        ]
      }
    },
    {
      "id": "answer_real_micro_assistant_registration",
      "category": "员工入口回答",
      "question": "外服微助手个人怎么注册并完成身份验证？",
      "expected": {
        "top_n": 5,
        "top_n_must_match_titles": [
          "微助手"
        ]
      },
      "answer_expected": {
        "must_include_terms": [
          "注册",
          "身份认证"
        ]
      },
      "citation_expected": {
        "min_count": 1,
        "max_count": 8,
        "must_match_titles": [
          "微助手"
        ],
        "must_not_match_titles": [
          "北仑派单"
        ]
      }
    },
    {
      "id": "answer_real_workorder_contract",
      "category": "工单流程回答",
      "question": "劳动合同续签信息通过工单系统交给谁，完成后怎么反馈？",
      "expected": {
        "top_n": 5,
        "top_n_must_match_titles": [
          "工单系统"
        ]
      },
      "answer_expected": {
        "must_include_terms": [
          "合同组",
          "工单",
