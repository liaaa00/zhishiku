  "cases": [
    {
      "id": "employee_esign_process_prefers_employee_guide",
      "question": "劳动合同电子签流程是什么？",
      "intent": "employee_esign_process",
      "expected": {
        "top_doc": "eval-doc-employee-esign",
        "must_include_docs": ["eval-doc-employee-esign"],
        "must_not_include_docs": ["eval-doc-workorder-internal", "eval-doc-form-noise"],
        "query_profile": {
          "task": "esign_process",
          "actor": "employee"
        },
        "must_have_positive_signals": ["外服云", "微助手", "点击签署"]
      }
    },
    {
      "id": "employee_esign_registration_support_can_be_recalled",
      "question": "微助手注册后怎么进入劳动合同签署入口？",
      "intent": "employee_esign_support",
      "expected": {
        "top_n": 3,
        "top_n_must_include_docs": ["eval-doc-micro-assistant", "eval-doc-employee-esign"],
        "must_not_include_docs": ["eval-doc-workorder-internal"],
        "query_profile": {
          "task": "esign_process",
          "actor": "employee"
        }
      }
    },
    {
      "id": "internal_contract_workflow_retrieves_workorder",
      "question": "合同组内部审核和盖章归档流程是什么？",
      "intent": "internal_contract_workflow",
      "expected": {
        "top_n": 3,
        "top_n_must_include_docs": ["eval-doc-workorder-internal"],
        "must_include_terms": ["合同组", "盖章", "归档"]
      }
    },
    {
      "id": "table_deadline_uses_table_backend",
      "question": "上海社保公积金截止时间表里2026年3月社保截止时间是什么？",
      "intent": "table_deadline",
      "expected": {
        "backend": "table",
        "must_include_docs": ["eval-doc-shanghai-social-security-table"],
        "must_not_include_docs": ["eval-doc-employee-esign", "eval-doc-workorder-internal"],
        "must_include_terms": ["2026-03-15"]
      }
    }
  ]
}
