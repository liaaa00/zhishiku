{
  "version": 1,
  "description": "数据驱动的检索评测集。默认使用 fixture 文档构造隔离 SQLite 库；后续可把真实业务问题逐步补到 cases 里。",
  "defaults": {
    "top_k": 8,
    "user_id": "eval-user"
  },
  "fixture": {
    "admin": {
      "id": "eval-admin",
      "username": "eval_admin",
      "password": "eval_admin_password"
    },
    "users": [
      {
        "id": "eval-user",
        "username": "eval_user",
        "password": "eval_user_password",
        "groups": ["eval-group"]
      }
    ],
    "groups": [
      {
        "id": "eval-group",
        "name": "Eval Group"
      }
    ],
    "documents": [
      {
