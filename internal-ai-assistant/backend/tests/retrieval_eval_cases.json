        "groups": ["eval-group"],
        "chunks": [
          "员工收到短信后，登录外服云或微助手进入员工服务入口，打开电子合同页面，核对劳动合同信息后点击签署。签署完成后系统提示完成。"
        ]
      },
      {
        "id": "eval-doc-micro-assistant",
        "title": "外服云微助手注册登录流程",
        "filename": "eval_micro_assistant_login.txt",
