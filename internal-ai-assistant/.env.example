APP_ENV=development
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=please-change-this-secret
MAX_UPLOAD_MB=200
# PostgreSQL primary database for Docker Compose.
# Set POSTGRES_PASSWORD to a strong secret before first production startup.
POSTGRES_DB=internal_ai_assistant
POSTGRES_USER=internal_ai
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://internal_ai:replace-with-strong-postgres-password@postgres:5432/internal_ai_assistant

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-v4-flash

# PageIndex 仅作为可选兼容索引，默认关闭；只有专项结构检索评测证明有收益时再启用。
PAGEINDEX_ENABLED=0
PAGEINDEX_MIN_CHARS=1
PAGEINDEX_REPO_PATH=
# PAGEINDEX_MODEL=openai/deepseek-chat
# PAGEINDEX_RETRIEVE_MODEL=openai/deepseek-chat
# PAGEINDEX_FORCE_LIGHTWEIGHT=1

# Qdrant 向量库。Docker Compose 内使用 http://qdrant:6333；本地 Python 直跑可改为 http://localhost:6333。
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=internal_ai_chunks

# Embedding 生成方式：local 便于本地试用；APP_ENV=production 会拒绝 local-hash。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash
EMBEDDING_DIM=512
# 本地 Ollama 示例（bge-m3 输出 1024 维向量）：
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_BASE_URL=http://ollama:11434/v1
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_API_KEY=ollama
# EMBEDDING_DIM=1024
# OLLAMA_EMBEDDING_MODEL=bge-m3
# 外部 OpenAI-compatible 服务只需替换 BASE_URL、MODEL 和 API_KEY。

# 知识图谱抽取：默认开启；正式导入前可按成本/质量要求调整。
GRAPH_EXTRACTION_ENABLED=1
GRAPH_AUTO_CONFIRM_THRESHOLD=0.85
GRAPH_PENDING_THRESHOLD=0.60
GRAPH_MAX_CHUNKS_PER_DOCUMENT=80
GRAPH_MAX_CHARS_PER_CHUNK=3000

# PDF OCR：文本过少时尝试视觉识别，页数越大成本越高。
PDF_OCR_MAX_PAGES=20
PDF_OCR_MIN_TEXT_CHARS=80
PDF_OCR_ZOOM=2.0

# CORS 允许的来源，逗号分隔（开发环境默认覆盖后端内嵌页 localhost:8080 与本项目前端 localhost:5174）
CORS_ORIGINS=http://localhost:8080,http://localhost:5174
