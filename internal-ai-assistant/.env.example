DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=please-change-this-secret
MAX_UPLOAD_MB=200

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-v4-flash

# PageIndex 高级结构索引：默认开启内置轻量结构树；配置 PAGEINDEX_REPO_PATH 并安装 backend/requirements-pageindex.txt 后可使用官方 VectifyAI/PageIndex。
PAGEINDEX_ENABLED=1
PAGEINDEX_MIN_CHARS=1
PAGEINDEX_REPO_PATH=
# PAGEINDEX_MODEL=openai/deepseek-chat
# PAGEINDEX_RETRIEVE_MODEL=openai/deepseek-chat
# PAGEINDEX_FORCE_LIGHTWEIGHT=1

# Qdrant 向量库。Docker Compose 内使用 http://qdrant:6333；本地 Python 直跑可改为 http://localhost:6333。
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=internal_ai_chunks

# Embedding 生成方式：local 便于本地试用；生产可改为 openai/openai-compatible。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash
EMBEDDING_DIM=512

# CORS 允许的来源，逗号分隔（开发环境默认覆盖后端内嵌页 localhost:8080 与本项目前端 localhost:5174）
CORS_ORIGINS=http://localhost:8080,http://localhost:5174
